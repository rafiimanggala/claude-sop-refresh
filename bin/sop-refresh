#!/usr/bin/env bash
# sop-refresh — force a re-broadcast of your Claude Code instructions to every
# live session.
#
# How it works (lazy model):
#   Each session auto-detects instruction changes via the watch.sh hook, which
#   hashes CLAUDE.md + rules/*.md on every prompt. Editing those files is ALREADY
#   enough to trigger a refresh on each session's next prompt. This command bumps
#   a nonce so a refresh fires even when no file changed (e.g. you want to
#   re-assert the instructions), and reports who will pick it up.
#
# Usage:
#   sop-refresh            bump + report live sessions
#   sop-refresh --status   report only, no bump
#   sop-refresh --note "x" bump and log a note

set -uo pipefail
ROOT="${HOME}/.claude"
NONCE="${ROOT}/.sop-nonce"
SESS_DIR="${ROOT}/sessions"
LOG="${ROOT}/hooks/sop-refresh/logs/sop.log"

mode="bump"; note=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --status) mode="status" ;;
    --broadcast) mode="bump" ;;   # friendly alias
    --note) shift; note="${1:-}" ;;
    -h|--help) sed -n '2,24p' "$0"; exit 0 ;;
  esac
  shift
done

ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
if [[ "$mode" == "bump" ]]; then
  printf '%s %s' "$ts" "$note" > "$NONCE"
  printf '%s [cli] bump nonce note="%s"\n' "$ts" "$note" >> "$LOG" 2>/dev/null || true
  echo "✓ instruction nonce bumped @ ${ts}"
  [[ -n "$note" ]] && echo "  note: ${note}"
else
  echo "ℹ status only (no bump)"
fi

echo ""
echo "Live sessions:"
found=0; busy=0
now_ms=$(( $(date +%s) * 1000 ))
fmt_dur() {  # ms → human (Xs / Xm / Xh Ym)
  local ms=$1 s
  (( ms < 0 )) && ms=0
  s=$(( ms / 1000 ))
  if   (( s < 60 ));   then printf '%ds' "$s"
  elif (( s < 3600 )); then printf '%dm' "$(( s / 60 ))"
  else printf '%dh %dm' "$(( s / 3600 ))" "$(( (s % 3600) / 60 ))"
  fi
}
if [[ -d "$SESS_DIR" ]]; then
  for f in "$SESS_DIR"/*.json; do
    [[ -e "$f" ]] || continue
    pid="$(jq -r '.pid // empty' "$f" 2>/dev/null)"
    [[ "$pid" =~ ^[0-9]+$ ]] || continue
    # only sessions whose process is still alive
    kill -0 "$pid" 2>/dev/null || continue
    sid="$(jq -r '.sessionId // empty' "$f" 2>/dev/null)"
    st="$(jq -r '.status // "?"' "$f" 2>/dev/null)"
    cwd="$(jq -r '.cwd // "?"' "$f" 2>/dev/null)"
    upd="$(jq -r '.updatedAt // empty' "$f" 2>/dev/null)"
    [[ "$upd" =~ ^[0-9]+$ ]] || upd=""
    if [[ -n "$upd" ]]; then dur="$(fmt_dur $(( now_ms - upd )))"; else dur="?"; fi
    case "$st" in
      busy) when="waits until the task finishes → refresh on the next turn"; busy=$((busy+1)); age="active ${dur} ago" ;;
      *)    when="refresh on the next prompt"; age="idle ${dur}" ;;
    esac
    printf '  • pid=%-6s status=%-8s %-16s %s  %s\n' "$pid" "$st" "$age" "${sid:0:8}" "$cwd"
    printf '      ↳ %s\n' "$when"
    found=$((found+1))
  done
fi
[[ "$found" -eq 0 ]] && echo "  (none detected)"
echo ""
echo "Total live=${found}, busy=${busy}. Refresh is lazy (applied at a turn boundary, never interrupting a task)."
